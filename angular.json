{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "d83a0693-9a8f-4215-9c76-fe02c3429cc3"
  },
  "newProjectRoot": "projects",
  "projects": {
    "mentee-portal": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/mentee-portal",
      "sourceRoot": "projects/mentee-portal/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/mentee-portal/src/main.ts",
            "tsConfig": "projects/mentee-portal/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/mentee-portal/public"
              }
            ],
            "styles": ["projects/mentee-portal/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "mentee-portal:build:production"
            },
            "development": {
              "buildTarget": "mentee-portal:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
