    },
    {
      "path": "./projects/website/tsconfig.spec.json"
    },
    {
      "path": "./projects/auth/tsconfig.lib.json"
    },
    {
      "path": "./projects/auth/tsconfig.spec.json"
    },
    {
      "path": "./projects/ui/tsconfig.lib.json"
    },
    {
      "path": "./projects/ui/tsconfig.spec.json"
    },
    {
      "path": "./projects/data-access/tsconfig.lib.json"
    },
    {
      "path": "./projects/data-access/tsconfig.spec.json"
    },
    {
      "path": "./projects/utils/tsconfig.lib.json"
    },
    {
